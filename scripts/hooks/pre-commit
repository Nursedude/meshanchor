#!/bin/bash
# MeshForge Pre-Commit Hook
# ==========================
# Ensures code quality before commits. Designed for reliability-critical
# mesh networking software used by HAMs, scientists, and network engineers.
#
# Checks performed:
# 1. Security linting (MF001-MF004 rules)
# 2. Fast test suite (critical tests only)
# 3. Type checking (if mypy available)
#
# Install: ./scripts/install-hooks.sh
# Bypass:  git commit --no-verify (use sparingly!)

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Get repository root
REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# Track failures
FAILED=0

echo "========================================"
echo "  MeshForge Pre-Commit Quality Check"
echo "========================================"
echo ""

# ---------------------------------------------------------------------------
# STAGE 1: Security Linting
# ---------------------------------------------------------------------------
echo -e "${YELLOW}[1/3] Running security linter...${NC}"

if [ -f "$REPO_ROOT/scripts/lint.py" ]; then
    # Get staged Python files
    STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)

    if [ -n "$STAGED_FILES" ]; then
        if python3 scripts/lint.py --staged --severity error 2>/dev/null; then
            echo -e "${GREEN}      Linting passed${NC}"
        else
            echo -e "${RED}      Linting FAILED - security issues found${NC}"
            FAILED=1
        fi
    else
        echo -e "${GREEN}      No Python files staged${NC}"
    fi
else
    echo -e "${YELLOW}      lint.py not found, skipping${NC}"
fi

# ---------------------------------------------------------------------------
# STAGE 2: Critical Tests
# ---------------------------------------------------------------------------
echo -e "${YELLOW}[2/3] Running critical tests...${NC}"

# Check if pytest is available
if command -v python3 &> /dev/null && python3 -c "import pytest" 2>/dev/null; then
    # Run fast critical tests only (security, paths, core utils)
    # Use -x to fail fast, --tb=no for minimal output
    CRITICAL_TESTS=(
        "tests/test_security.py"
        "tests/test_paths.py"
        "tests/test_common.py"
        "tests/test_rf_utils.py"
    )

    # Filter to only existing test files
    EXISTING_TESTS=""
    for test in "${CRITICAL_TESTS[@]}"; do
        if [ -f "$REPO_ROOT/$test" ]; then
            EXISTING_TESTS="$EXISTING_TESTS $test"
        fi
    done

    if [ -n "$EXISTING_TESTS" ]; then
        if python3 -m pytest $EXISTING_TESTS -x -q --tb=no 2>/dev/null; then
            echo -e "${GREEN}      Critical tests passed${NC}"
        else
            echo -e "${RED}      Critical tests FAILED${NC}"
            echo "      Run 'python3 -m pytest tests/ -v' for details"
            FAILED=1
        fi
    else
        echo -e "${YELLOW}      No critical test files found${NC}"
    fi
else
    echo -e "${YELLOW}      pytest not available, skipping tests${NC}"
fi

# ---------------------------------------------------------------------------
# STAGE 3: Type Checking (Optional)
# ---------------------------------------------------------------------------
echo -e "${YELLOW}[3/3] Running type checker...${NC}"

if command -v python3 &> /dev/null && python3 -c "import mypy" 2>/dev/null; then
    # Only check staged files for speed
    STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' | head -20 || true)

    if [ -n "$STAGED_PY" ]; then
        # Run mypy with minimal config, errors only
        if python3 -m mypy --ignore-missing-imports --no-error-summary $STAGED_PY 2>/dev/null; then
            echo -e "${GREEN}      Type checking passed${NC}"
        else
            echo -e "${YELLOW}      Type issues found (non-blocking)${NC}"
            # Type errors are warnings, not blockers (yet)
        fi
    else
        echo -e "${GREEN}      No files to check${NC}"
    fi
else
    echo -e "${YELLOW}      mypy not available, skipping${NC}"
fi

# ---------------------------------------------------------------------------
# RESULT
# ---------------------------------------------------------------------------
echo ""
echo "========================================"

if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}  All checks passed - commit allowed${NC}"
    echo "========================================"
    exit 0
else
    echo -e "${RED}  Checks FAILED - commit blocked${NC}"
    echo "========================================"
    echo ""
    echo "Fix the issues above, then try again."
    echo "To bypass (emergency only): git commit --no-verify"
    echo ""
    exit 1
fi
