# MeshCore companion radio udev rules
# Provides persistent /dev/ttyMeshCore symlink across reboots.
#
# Install:
#   sudo cp scripts/99-meshcore.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules && sudo udevadm trigger
#
# Supported devices (USB serial adapters used by MeshCore radios):
#   - CP210x (Silicon Labs) — Heltec V3/V4, some RAK boards
#   - CH340/CH341 — clone boards, some Heltec variants
#   - ESP32-S3 native USB — Heltec Wireless Stick Lite V3 (E213)
#   - nRF52840 USB CDC — RAK4631
#
# After install, configure MeshAnchor to use /dev/ttyMeshCore instead of
# /dev/ttyUSB0 — the symlink survives reboots and USB re-enumeration.

# CP210x (Silicon Labs) — Heltec V3, Heltec V4, some RAK boards
SUBSYSTEM=="tty", ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", SYMLINK+="ttyMeshCore", MODE="0666"

# CH340/CH341 (WCH) — clone boards, some Heltec variants
SUBSYSTEM=="tty", ATTRS{idVendor}=="1a86", ATTRS{idProduct}=="7523", SYMLINK+="ttyMeshCore", MODE="0666"

# ESP32-S3 native USB CDC — Heltec Wireless Stick Lite V3 (E213)
SUBSYSTEM=="tty", ATTRS{idVendor}=="303a", ATTRS{idProduct}=="1001", SYMLINK+="ttyMeshCore", MODE="0666"

# nRF52840 USB CDC ACM — RAK4631
SUBSYSTEM=="tty", ATTRS{idVendor}=="239a", ATTRS{idProduct}=="8029", SYMLINK+="ttyMeshCore", MODE="0666"
