# MeshAnchor MeshCore Chat Pane — operator-tunable environment.
# ===============================================================
#
# Sourced by chat_client_wrapper.sh on every service start.  Edit
# this file to change the chat client's behaviour without touching
# the wrapper or unit templates.
#
# Edit via the TUI:
#   MeshCore > Chat (tmux pane) > Service Control > Edit config
# Or directly:
#   $EDITOR ~/.config/meshanchor/chat_pane.env
# Then apply:
#   systemctl --user restart meshcore-chat
#
# Both ``_chat_pane_service_ops.py::_install_user_unit`` and any
# future canonical install script copy this file as the seed value
# and never overwrite an existing user copy on refresh.
#
# Keys honoured by utils/chat_client.py:
#   MESHANCHOR_CHAT_API     — base URL of the gateway daemon's HTTP
#                             chat API. Default 127.0.0.1:8081 — the
#                             gateway is localhost-only by design.
#   MESHANCHOR_CHAT_CHANNEL — default outbound channel slot (int).
#                             Same as typing /ch <n> in the pane.
#   MESHANCHOR_CHAT_POLL    — poll interval seconds (float, min 0.5).
#                             2.0 is the sweet spot; lowering it eats
#                             gateway CPU without showing more traffic
#                             since the radio queue isn't faster.

MESHANCHOR_CHAT_API=http://127.0.0.1:8081
MESHANCHOR_CHAT_CHANNEL=0
MESHANCHOR_CHAT_POLL=2.0
