{
  "_comment": "MeshForge Gateway Template: RNS Over Meshtastic Transport",
  "_description": "Uses Meshtastic LoRa as a transport layer for RNS packets",
  "_usage": "Copy to ~/.config/meshforge/gateway.json and adjust settings",

  "enabled": true,
  "auto_start": false,
  "bridge_mode": "rns_transport",

  "meshtastic": {
    "_comment": "Used for status/diagnostics, transport uses rns_transport config",
    "host": "localhost",
    "port": 4403,
    "channel": 0,
    "use_mqtt": false,
    "mqtt_topic": "",
    "preset": "",
    "name": "primary"
  },

  "rns": {
    "config_dir": "",
    "identity_name": "meshforge_rns_transport",
    "announce_interval": 300,
    "propagation_node": ""
  },

  "rns_transport": {
    "_comment": "RNS packet transport over Meshtastic LoRa",
    "enabled": true,

    "connection_type": "tcp",
    "device_path": "localhost:4403",

    "data_speed": 8,
    "_speed_presets": {
      "8": "SHORT_TURBO - 500 B/s, short range (local testing)",
      "6": "SHORT_FAST - 300 B/s, medium range (urban mesh)",
      "4": "MEDIUM_FAST - 100 B/s, long range (suburban)",
      "0": "LONG_FAST - 50 B/s, maximum range (rural/emergency)"
    },

    "hop_limit": 3,

    "fragment_timeout_sec": 30,
    "max_pending_fragments": 100,

    "enable_stats": true,
    "stats_interval_sec": 60,

    "packet_loss_threshold": 0.1,
    "latency_threshold_ms": 5000
  },

  "mesh_bridge": {
    "enabled": false,
    "primary": {
      "host": "localhost",
      "port": 4403,
      "channel": 0,
      "use_mqtt": false,
      "mqtt_topic": "",
      "preset": "LONG_FAST",
      "name": "longfast"
    },
    "secondary": {
      "host": "localhost",
      "port": 4404,
      "channel": 0,
      "use_mqtt": false,
      "mqtt_topic": "",
      "preset": "SHORT_TURBO",
      "name": "shortturbo"
    },
    "direction": "bidirectional",
    "message_filter": "",
    "exclude_filter": "",
    "dedup_window_sec": 60,
    "add_prefix": true,
    "prefix_format": "[{source_preset}] "
  },

  "routing_rules": [],
  "default_route": "bidirectional",

  "telemetry": {
    "share_position": true,
    "share_battery": true,
    "share_environment": true,
    "position_precision": 5,
    "update_interval": 60
  },

  "log_level": "INFO",
  "log_messages": true,
  "ai_diagnostics_enabled": false,
  "snr_analysis": true,
  "anomaly_detection": false
}
