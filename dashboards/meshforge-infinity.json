            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "snr" },
            "properties": [
              { "id": "unit", "value": "dB" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "red", "value": null },
                { "color": "yellow", "value": -5 },
                { "color": "green", "value": 5 }
              ]}}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "battery" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "red", "value": null },
                { "color": "yellow", "value": 20 },
                { "color": "green", "value": 50 }
              ]}}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "online" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-text" },
              { "id": "mappings", "value": [
                { "type": "value", "options": { "true": { "text": "Online", "color": "green" }, "false": { "text": "Offline", "color": "red" } } }
              ]}
            ]
          }
        ]
