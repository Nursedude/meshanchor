        {
          "alias": "$tag_node_id",
          "query": "SELECT mean(\"snr\") FROM \"meshforge_node\" WHERE $timeFilter GROUP BY time($__interval), \"node_id\" fill(null)",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series"
        }
      ],
