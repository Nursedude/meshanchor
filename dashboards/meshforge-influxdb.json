          "mode": "multi",
          "sort": "none"
        }
      },
      "pluginVersion": "9.0.0",
      "targets": [
        {
          "alias": "Total Nodes",
          "query": "SELECT mean(\"total\") FROM \"meshforge_nodes\" WHERE $timeFilter GROUP BY time($__interval) fill(previous)",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series"
        },
        {
          "alias": "With GPS",
          "query": "SELECT mean(\"with_gps\") FROM \"meshforge_nodes\" WHERE $timeFilter GROUP BY time($__interval) fill(previous)",
          "rawQuery": true,
          "refId": "B",
          "resultFormat": "time_series"
        }
      ],
