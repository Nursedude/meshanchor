    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "index": 1, "text": "Disconnected" } }, "type": "value" },
            { "options": { "1": { "color": "green", "index": 0, "text": "Connected" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
