{
    "id": "org.meshforge.plugin.nanovna_analyzer",
    "name": "NanoVNA Antenna Analyzer",
    "version": "0.1.0",
    "description": "Real-time SWR, impedance, and frequency response analysis from NanoVNA devices",
    "author": "MeshForge",
    "type": "integration",
    "entry_point": "main.py",
    "min_meshforge_version": "0.4.0",
    "permissions": ["serial_access"],
    "dependencies": ["pyserial"],
    "settings_schema": {
        "serial_port": {
            "type": "string",
            "default": "",
            "description": "Serial port for NanoVNA connection"
        },
        "baud_rate": {
            "type": "number",
            "default": 115200,
            "description": "Serial baud rate"
        },
        "frequency_start_mhz": {
            "type": "number",
            "default": 400,
            "description": "Start frequency for sweep (MHz)"
        },
        "frequency_stop_mhz": {
            "type": "number",
            "default": 500,
            "description": "Stop frequency for sweep (MHz)"
        },
        "sweep_points": {
            "type": "number",
            "default": 101,
            "description": "Number of points in frequency sweep"
        },
        "auto_refresh": {
            "type": "boolean",
            "default": true,
            "description": "Auto-refresh data periodically"
        },
        "refresh_interval_ms": {
            "type": "number",
            "default": 2000,
            "description": "Auto-refresh interval in milliseconds"
        }
    }
}
