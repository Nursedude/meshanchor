{
  "_name": "RNS Transport Layer",
  "_description": "Use Meshtastic LoRa mesh as transport for Reticulum. Enables RNS apps over LoRa.",
  "_usage": "Copy to ~/.config/meshforge/gateway.json",

  "enabled": true,
  "auto_start": false,
  "bridge_mode": "rns_transport",

  "meshtastic": {
    "host": "localhost",
    "port": 4403,
    "channel": 0,
    "use_mqtt": false,
    "mqtt_topic": ""
  },

  "rns": {
    "config_dir": "",
    "identity_name": "meshforge_transport",
    "announce_interval": 300,
    "propagation_node": ""
  },

  "rns_transport": {
    "enabled": true,
    "connection_type": "tcp",
    "device_path": "localhost:4403",
    "data_speed": 5,
    "hop_limit": 3,
    "fragment_timeout_sec": 30,
    "max_pending_fragments": 100,
    "enable_stats": true,
    "stats_interval_sec": 60,
    "packet_loss_threshold": 0.1,
    "latency_threshold_ms": 5000
  },

  "telemetry": {
    "share_position": true,
    "share_battery": true,
    "share_environment": false,
    "update_interval": 120
  },

  "log_level": "INFO",
  "log_messages": true,
  "ai_diagnostics_enabled": true,
  "snr_analysis": true,
  "anomaly_detection": true
}
